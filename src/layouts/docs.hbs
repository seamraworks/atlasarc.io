<!DOCTYPE html>
<html lang="en">
<head>
  {{> head}}
  {{> html-head-block}}
  {{> analytics}}
</head>
<body class="chrome-docs">
  <div class="coming-soon-banner" aria-hidden="true">Coming soon</div>
  {{> site-header}}
  <div class="docs-shell">
    <aside class="docs-sidebar" aria-label="Documentation navigation">
      {{> docs-sidebar}}
    </aside>
    <main id="main" class="docs-content{{#if wideContent}} docs-content-wide{{/if}}" data-pagefind-body>
      {{> breadcrumbs}}
{{> body-block}}
    </main>
  </div>
  {{> footer}}
  <script type="module" src="/assets/scripts/nav.js"></script>
  <script type="module" src="/pagefind/pagefind-component-ui.js"></script>
  <script src="/assets/lib/prism-docs.js"></script>
  {{> scripts-block}}
</body>
</html>
