                <td><a href="/workflows/identify-hotspots">Identify risky hotspots</a>; <a href="/workflows/understand-subsystem-coupling">Understand subsystem coupling</a>; <a href="/workflows/show-me-the-backbone">Show me the backbone</a>; <a href="/workflows/cycle-tangle-reduction">Cycle / tangle reduction</a>; <a href="/workflows/zone-of-pain">Zone of Pain</a>; <a href="/workflows/ticking-time-bombs">Ticking time bombs</a>; <a href="/workflows/audit-a-module-boundary">Audit a module boundary</a>; <a href="/workflows/audit-a-subsystem">Audit a subsystem</a></td>
              </tr>
              <tr>
                <td>Abstractness</td>
                <td>A</td>
                <td>Public abstraction ratio; interfaces and abstract types compared with public type count.</td>
                <td><a href="/lenses/hotspots">Hotspots</a>, <a href="/lenses/subsystems">Subsystems</a>, <a href="/lenses/topology-graph">Topology Graph heatmap</a>, <a href="/lenses/package-matrix">Package Matrix heatmap</a>, <a href="/lenses/composition">Composition heatmap</a></td>
                <td><a href="/workflows/identify-hotspots">Identify risky hotspots</a>; <a href="/workflows/stable-but-too-concrete">Stable but too concrete</a>; <a href="/workflows/zone-of-pain">Zone of Pain</a>; <a href="/workflows/zone-of-uselessness">Zone of Uselessness</a>; <a href="/workflows/audit-a-subsystem">Audit a subsystem</a></td>
