{{#> marketing}}
  {{#*inline "html-head-block"}}
    <title>House Style | AtlasArc (internal)</title>
    <meta name="description" content="The AtlasArc house style: AtlasArc Target. A living reference and component library — internal, not part of the public site.">
    <meta name="robots" content="noindex">
    <link rel="stylesheet" href="/assets/styleguide.css">
  {{/inline}}

  {{#*inline "body-block"}}
  <div class="sg-page">

    <header class="sg-masthead">
      <div class="container">
        <p class="eyebrow">House style — AtlasArc Target</p>
        <h1>Drawn to scale. Built to ship.</h1>
        <p class="lede">The living reference for the AtlasArc website. The product reads architecture — nodes, edges, cycles, metrics — so the brand reads like the schematic of one: a structural grotesque, a technical mono, navy as the single signal, black for hard structure, white ground, and lines doing the work that shadows used to.</p>
        <div class="sg-meta">
          <span>v2.0 — AtlasArc Target</span>
          <span>internal — excluded from sitemap</span>
          <span>edit src/styles/tokens.less to retune</span>
        </div>
      </div>
    </header>

    <!-- 01 Voice -->
    <section class="sg-section">
      <div class="container">
        <div class="sg-section-head">
          <span class="sg-index">01 / voice</span>
          <h2>Principles</h2>
          <p class="sg-note">Three rules that keep the design honest. When a choice is unclear, these break the tie.</p>
        </div>
        <ul class="card-grid">
          <li class="card"><a href="#01"><h3>Structure, not decoration</h3><p>A rule, a border, or a grid earns its place by clarifying structure. No gradients, no glow, no shadow — edges and weight carry the hierarchy.</p></a></li>
          <li class="card"><a href="#01"><h3>Read it like data</h3><p>Anything the machine produced — package names, metrics, coordinates — is set in mono. The reader should always know what is data and what is prose.</p></a></li>
          <li class="card"><a href="#01"><h3>Decisive, not loud</h3><p>One navy signal. Hard corners. Heavy display weight against light body weight. Confident without shouting; technical without being cold.</p></a></li>
        </ul>
      </div>
    </section>

    <!-- 02 Colour -->
    <section class="sg-section">
      <div class="container">
        <div class="sg-section-head">
          <span class="sg-index">02 / colour</span>
          <h2>Palette</h2>
          <p class="sg-note">White ground, black structure, navy signal. Grey carries alternating bands and borders. Health and caveat are semantic — used only to mean something.</p>
        </div>
        <ul class="sg-swatches">
          <li class="sg-swatch"><div class="sg-chip" style="background:#ffffff;border:1px solid #ccc"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@canvas</div><div class="sg-swatch-hex">#ffffff</div><div class="sg-swatch-role">Page ground</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#f2f2f2"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@surface-sunk</div><div class="sg-swatch-hex">#f2f2f2</div><div class="sg-swatch-role">Alternating bands</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#000000"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@ink</div><div class="sg-swatch-hex">#000000</div><div class="sg-swatch-role">Text & structure</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#555555"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@ink-soft</div><div class="sg-swatch-hex">#555555</div><div class="sg-swatch-role">Secondary text</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#cccccc"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@line</div><div class="sg-swatch-hex">#cccccc</div><div class="sg-swatch-role">Borders, hairlines</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#1a3556"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@arc</div><div class="sg-swatch-hex">#1a3556</div><div class="sg-swatch-role">Signal — navy</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#2d4f7a"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@arc-deep</div><div class="sg-swatch-hex">#2d4f7a</div><div class="sg-swatch-role">Navy hover</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#e8edf3"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@arc-tint</div><div class="sg-swatch-hex">#e8edf3</div><div class="sg-swatch-role">Navy wash</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#2a7050"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@verdigris</div><div class="sg-swatch-hex">#2a7050</div><div class="sg-swatch-role">Healthy / stable</div></div></li>
          <li class="sg-swatch"><div class="sg-chip" style="background:#fbeed3"></div><div class="sg-swatch-meta"><div class="sg-swatch-name">@caveat-bg</div><div class="sg-swatch-hex">#fbeed3</div><div class="sg-swatch-role">Caveat wash</div></div></li>
        </ul>
      </div>
    </section>

    <!-- 03 Typography -->
    <section class="sg-section">
      <div class="container">
        <div class="sg-section-head">
          <span class="sg-index">03 / type</span>
          <h2>Typography</h2>
          <p class="sg-note">DM Sans does both display and body — hierarchy comes from weight contrast (300 lede against 900 display), not from a second family. IBM Plex Mono sets anything the machine produced.</p>
        </div>
        <div class="sg-panel">
          <div class="sg-type-row">
            <div class="sg-type-label">DM Sans 900 — display</div>
            <div class="sg-display">Find the cycle.</div>
          </div>
          <div class="sg-type-row">
            <div class="sg-type-label">DM Sans — weight contrast</div>
            <div class="sg-weights">
              <span class="sg-w300">300 Light</span>
              <span class="sg-w400">400 Regular</span>
              <span class="sg-w500">500 Medium</span>
              <span class="sg-w700">700 Bold</span>
              <span class="sg-w900">900 Black</span>
            </div>
          </div>
          <div class="sg-type-row">
            <div class="sg-type-label">DM Sans 300 — body / lede</div>
            <p class="sg-specimen-sans" style="margin:0;font-size:1.05rem;line-height:1.7">AtlasArc visualizes dependencies, cycles, hotspots, subsystems, and architecture metrics directly inside IntelliJ IDEA — so you can read the shape of a codebase before you change it.</p>
          </div>
          <div class="sg-type-row">
            <div class="sg-type-label">IBM Plex Mono — technical</div>
            <p class="sg-specimen-mono" style="margin:0">com.atlasarc.core.graph &nbsp;&middot;&nbsp; fan-in: 14 &nbsp;&middot;&nbsp; instability: 0.82 &nbsp;&middot;&nbsp; cycle: A &rarr; B &rarr; A</p>
          </div>
          <div class="sg-type-row">
            <div class="sg-type-label">Mono glyph set</div>
            <div class="sg-glyphs">ABCDEFG abcdefg 0123456789 {} [] () &rarr; &rArr; &harr; // &amp;&amp;</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 04 Spacing -->
    <section class="sg-section">
      <div class="container">
        <div class="sg-section-head">
          <span class="sg-index">04 / measure</span>
          <h2>Spacing &amp; structure</h2>
          <p class="sg-note">A short, doubling-ish scale keeps rhythm predictable. There is no border-radius and no shadow anywhere — structure is carried by 1px hairlines and 2px section rules.</p>
        </div>
        <div class="sg-panel">
          <ul class="sg-scale">
            <li><span class="sg-scale-label">2xs · 4px</span><span class="sg-scale-bar" style="width:4px"></span></li>
            <li><span class="sg-scale-label">xs · 8px</span><span class="sg-scale-bar" style="width:8px"></span></li>
            <li><span class="sg-scale-label">sm · 12px</span><span class="sg-scale-bar" style="width:12px"></span></li>
            <li><span class="sg-scale-label">md · 16px</span><span class="sg-scale-bar" style="width:16px"></span></li>
            <li><span class="sg-scale-label">lg · 32px</span><span class="sg-scale-bar" style="width:32px"></span></li>
            <li><span class="sg-scale-label">xl · 64px</span><span class="sg-scale-bar" style="width:64px"></span></li>
            <li><span class="sg-scale-label">2xl · 96px</span><span class="sg-scale-bar" style="width:96px"></span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 05 Buttons & links -->
    <section class="sg-section">
      <div class="container">
        <div class="sg-section-head">
          <span class="sg-index">05 / actions</span>
          <h2>Buttons &amp; links</h2>
          <p class="sg-note">Hard, decisive. The primary fills navy; the ghost is a 2px solid black outline. The compact <code>btn-nav</code> sits in the header. Links are navy and underline on hover.</p>
        </div>
        <div class="sg-panel sg-stack">
          <div class="sg-row">
            <a class="btn btn-primary" href="#05">Start free trial</a>
            <a class="btn btn-ghost" href="#05">Explore workflows</a>
            <a class="btn-nav" href="#05">Start free trial</a>
          </div>
          <p style="margin:0">Inline links read in <a href="#05">navy with a hover underline</a>. Technical references read as <code>com.atlasarc.metrics</code> in mono.</p>
        </div>
      </div>
    </section>

    <!-- 06 Navigation -->
    <section class="sg-section">
      <div class="container">
        <div class="sg-section-head">
          <span class="sg-index">06 / navigation</span>
          <h2>Site header</h2>
