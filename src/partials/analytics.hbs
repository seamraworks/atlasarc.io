{{#if site.analytics}}
  {{#if (eq site.analytics.provider "plausible")}}
    {{#unless page.internal}}
      <script async src="https://plausible.io/js/pa-{{site.analytics.scriptId}}.js"></script>
      <script>
        window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
        plausible.init()
      </script>
    {{/unless}}
  {{/if}}
{{/if}}
