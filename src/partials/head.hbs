<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700;9..40,900&family=IBM+Plex+Mono:wght@400;500;600&display=block">
{{#each styleHrefs}}
<link rel="stylesheet" href="{{this}}">
{{/each}}
{{#each prefetchStyleHrefs}}
<link rel="prefetch" href="{{this}}" as="style">
{{/each}}
{{#each prefetchUrls}}
<link rel="prefetch" href="{{this}}">
{{/each}}
