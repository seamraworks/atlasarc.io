<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title>Copy Style Audit | AtlasArc</title>
  <style>
    :root {
      --ink: #121212;
      --muted: #5b626b;
      --line: #d8dde3;
      --surface: #f6f7f9;
      --high: #a62222;
      --medium: #8a5a00;
      --low: #345f87;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--ink);
      background: #fff;
      font-family: Arial, Helvetica, sans-serif;
      line-height: 1.45;
    }
    main {
      width: min(1500px, calc(100vw - 32px));
      margin: 0 auto;
      padding: 28px 0 48px;
    }
    h1 {
      margin: 0 0 6px;
      font-size: 28px;
      line-height: 1.1;
    }
    .meta {
      margin: 0 0 20px;
      color: var(--muted);
      font-size: 14px;
    }
    .summary {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0 0 18px;
    }
    .acceptance {
      border: 1px solid var(--line);
      background: var(--surface);
      padding: 12px 14px;
      margin: 0 0 18px;
    }
    .acceptance h2 {
      margin: 0 0 8px;
      font-size: 15px;
    }
    .acceptance ul {
      margin: 0;
      padding-left: 20px;
    }
    .acceptance li {
      margin: 4px 0;
      font-size: 13px;
    }
    .pill {
      border: 1px solid var(--line);
      padding: 4px 8px;
      font-size: 13px;
      font-weight: 700;
      background: var(--surface);
    }
    .pill.high { color: var(--high); }
    .pill.medium { color: var(--medium); }
    .pill.low { color: var(--low); }
    .pill.triage { color: var(--high); border-color: #e0a3a3; background: #fff5f5; }
    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      border: 1px solid var(--line);
    }
    th,
    td {
      vertical-align: top;
      border: 1px solid var(--line);
      padding: 8px;
      font-size: 13px;
    }
    th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: #eef1f5;
      text-align: left;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    td {
      overflow-wrap: anywhere;
      background: #fff;
    }
    tr:nth-child(even) td { background: #fbfcfd; }
    tr.needs-triage td {
      background: #fff5f5;
      border-color: #e0a3a3;
    }
    code {
      font-family: Consolas, "Liberation Mono", monospace;
      font-size: 12px;
    }
    .severity {
      font-weight: 800;
      text-transform: uppercase;
    }
    .severity.high { color: var(--high); }
    .severity.medium { color: var(--medium); }
    .severity.low { color: var(--low); }
    .source {
      color: var(--muted);
      font-size: 12px;
    }
    .triage-badge {
      display: inline-block;
      margin-left: 6px;
      color: var(--high);
      font-weight: 800;
      font-size: 11px;
      letter-spacing: 0.04em;
    }
    .triage-text {
      color: var(--high);
      font-weight: 800;
    }
    .text {
      min-width: 280px;
    }
    .empty {
      border: 1px solid var(--line);
      background: var(--surface);
      padding: 18px;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <main>
    <h1>Copy Style Audit</h1>
    <p class="meta">Track: <code>{{track}}</code>. Generated {{generatedAt}} from <code>{{reportPathRelative}}</code>. JSON copy: <code>{{reportJsonRelative}}</code>.</p>
    <div class="summary" aria-label="Finding summary">
      <span class="pill">Total: {{summary.total}}</span>
      <span class="pill high">High: {{summary.high}}</span>
      <span class="pill medium">Medium: {{summary.medium}}</span>
      <span class="pill low">Low: {{summary.low}}</span>
      <span class="pill">Accepted: {{triage.acceptedCount}}</span>
      <span class="pill triage">Needs triage: {{triage.untriagedCount}}</span>
      <span class="pill">Stale purged: {{triage.staleFindingsPurged}}</span>
      {{#if openai.enabled}}<span class="pill">OpenAI: {{openai.model}}</span>{{/if}}
      {{#if openai.skippedReason}}<span class="pill">OpenAI skipped: {{openai.skippedReason}}</span>{{/if}}
    </div>
    {{#if acceptanceRules.length}}
      <section class="acceptance" aria-label="Acceptance rules">
        <h2>Acceptance Rules</h2>
        <ul>
          {{#each acceptanceRules}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </section>
    {{/if}}
    {{#if findings.length}}
      <table>
        <thead>
          <tr>
            <th style="width: 100px;">Triage</th>
            <th style="width: 82px;">Severity</th>
            <th style="width: 88px;">Source</th>
            <th style="width: 220px;">File</th>
            <th style="width: 64px;">Line</th>
            <th class="text">Text</th>
            <th>Reason</th>
            <th>Acceptance / Next Step</th>
          </tr>
        </thead>
        <tbody>
          {{#each findings}}
            <tr class="{{#unless triageAccepted}}needs-triage{{/unless}}">
              <td><span class="{{#unless triageAccepted}}triage-badge{{/unless}}">{{triage}}</span></td>
              <td><span class="severity {{severity}}">{{severity}}</span></td>
              <td><span class="source">{{source}}</span></td>
              <td><code>{{file}}</code></td>
              <td>{{line}}</td>
              <td class="text">{{#unless triageAccepted}}<strong class="triage-text">{{exactText}}</strong>{{else}}{{exactText}}{{/unless}}</td>
              <td>{{reason}}</td>
              <td>
                {{#if suggestedRewrite}}{{suggestedRewrite}}<br>{{/if}}
                <span class="source">{{needs}}</span>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="empty">No copy style findings.</p>
    {{/if}}
  </main>
</body>
</html>
