{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": false,
    "outDir": "dist/assets/scripts",
    "rootDir": "src/scripts",
    "paths": {
      "/pagefind/pagefind-ui.js": ["./src/scripts/pagefind.d.ts"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/scripts/**/*.ts"]
}
